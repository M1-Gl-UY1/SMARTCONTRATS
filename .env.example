# =========================================================================
# FURSA Smart Contracts - variables d'environnement
# Copier ce fichier en .env (jamais commite, voir .gitignore)
# =========================================================================

# Alchemy Sepolia (https://dashboard.alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/REMPLACER_PAR_TA_KEY

# Cle privee du wallet deployer FURSA (MetaMask -> Export private key)
# DOIT commencer par 0x. NE JAMAIS COMMITER. NE JAMAIS PARTAGER.
SEPOLIA_DEPLOYER_PRIVATE_KEY=0xREMPLACER_PAR_TA_CLE_PRIVEE

# Etherscan API key pour publier le code source (optionnel mais recommande)
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=REMPLACER_OU_LAISSER_VIDE
